# Copy this file to .env and fill in your key.
#
# Get a free NVIDIA API key (no credit card) at: https://build.nvidia.com
# Sign up → top-right avatar → "API Key" → Generate Key
#
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides (defaults work fine for the demo):
# MODEL_NAME=nvidia/llama-3.3-nemotron-super-49b-v1.5
# BASE_URL=https://integrate.api.nvidia.com/v1
